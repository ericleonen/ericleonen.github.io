---
interface Props {
  title: string;
  date: Date;
  summary?: string;
  href: string;
}

const { title, date, summary, href } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={href} class="block group">
  <p class="text-xs text-gray-400 mb-1">{formattedDate}</p>
  <h3 class="font-medium group-hover:underline">{title}</h3>
  {summary && <p class="text-sm text-gray-500 mt-1">{summary}</p>}
</a>
