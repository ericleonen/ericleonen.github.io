---
import Link from './Link.astro';
import type { render } from 'astro:content';

type ContentComponent = Awaited<ReturnType<typeof render>>['Content'];

interface Props {
  title: string;
  date: Date;
  id: string;
  images?: { src: string; alt: string }[];
  links?: { label: string; url: string }[];
  Content: ContentComponent;
}

const { title, date, id, images, links, Content } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});

---

<div class="flex flex-col gap-3">
  {images && images.length > 0 && (
    <div class="flex gap-2 overflow-x-auto pb-1">
      {images.map(img => (
        <div class="group relative h-24 shrink-0 rounded overflow-hidden border">
          <img
            src={img.src}
            alt={img.alt}
            class="h-full w-auto object-cover"
          />
          <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-black/60 px-2 py-1 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
            <p class="text-xs text-white leading-tight">{img.alt}</p>
          </div>
        </div>
      ))}
    </div>
  )}
  <div class="min-w-0">
    <h3 class="font-medium">{title}</h3>
    <div class="flex flex-wrap items-baseline gap-x-3 text-sm mt-1">
      <span class="text-xs text-gray-400 shrink-0">{formattedDate}</span>
      {links && links.map(link => (
        <Link href={link.url} external>{link.label}</Link>
      ))}
    </div>
    <div class="text-sm text-gray-700 mt-3 prose prose-sm prose-gray max-w-none">
      <Content />
    </div>
  </div>
</div>
