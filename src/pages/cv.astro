---
import Layout from '../layouts/Layout.astro';
import Highlight from '../components/Highlight.astro';
import Link from '../components/Link.astro';
import cv from '../content/cv.json';

const TEX_URL = 'https://ericleonen.github.io/ericleonen-cv.tex';
const pdfUrl = `https://latex.ytotech.com/builds/sync?url=${encodeURIComponent(TEX_URL)}&compiler=pdflatex`;
---

<Layout title="CV — Eric Leonen">
  <div class="flex justify-between items-baseline mb-8">
    <h1 class="text-2xl font-bold">CV</h1>
    <Link href={pdfUrl} color="orange" class="text-sm font-medium" target="_blank" rel="noopener">
      Download PDF →
    </Link>
  </div>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>education</Highlight></h2>
    {cv.education.map(edu => (
      <div>
        <div class="flex justify-between items-baseline">
          <span class="font-medium">{edu.institution}</span>
          <span class="text-sm text-gray-500">{edu.location}</span>
        </div>
        <div class="flex justify-between items-baseline">
          <span class="text-sm">{edu.degree}</span>
          <span class="text-sm text-gray-500">{edu.graduated}</span>
        </div>
        <p class="text-sm mt-1">GPA: {edu.gpa}</p>
        <p class="text-sm text-gray-500 mt-1">
          <span class="italic">Relevant Coursework:</span> {edu.coursework.join(', ')}
        </p>
      </div>
    ))}
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>research experience</Highlight></h2>
    <div class="space-y-6">
      {cv.research.map(r => (
        <div>
          <p class="font-medium">{r.title}</p>
          <div class="flex justify-between items-baseline">
            <span class="text-sm text-gray-500 italic">{r.organization}, {r.location}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{r.dates}</span>
          </div>
          <ul class="mt-1 list-disc list-inside text-sm space-y-0.5">
            {r.bullets.map(b => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>projects</Highlight></h2>
    <div class="space-y-4">
      {cv.projects.map(p => (
        <div>
          <div class="flex justify-between items-baseline">
            <span class="font-medium">{p.title}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{p.dates}</span>
          </div>
          <p class="text-sm">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-4"><Highlight>skills</Highlight></h2>
    <div class="space-y-1">
      {Object.entries(cv.skills).map(([cat, items]) => (
        <p class="text-sm">
          <span class="font-medium">{cat}:</span> {(items as string[]).join(', ')}
        </p>
      ))}
    </div>
  </section>
</Layout>
