---
import Layout from '../layouts/Layout.astro';
import Highlight from '../components/Highlight.astro';
import Link from '../components/Link.astro';
import { Icon } from 'astro-icon/components';
import cv from '../content/cv.json';

function dash(str: string) {
  return str.replace(/--/g, '–');
}
---

<Layout title="CV — Eric Leonen">
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-2xl font-bold mb-1">CV</h1>
      <p class="text-sm text-gray-500">
        {cv.contact.location} · {cv.contact.phone} ·
        <a href={`mailto:${cv.contact.email}`} class="text-blue-500 hover:underline">{cv.contact.email}</a> ·
        <a href={`https://${cv.contact.github}`} target="_blank" rel="noopener" class="text-blue-500 hover:underline">{cv.contact.github}</a> ·
        <a href={`https://${cv.contact.linkedin}`} target="_blank" rel="noopener" class="text-blue-500 hover:underline">LinkedIn</a>
      </p>
    </div>
    <Link href="/ericleonen-cv.pdf" class="flex items-center gap-1.5 text-sm shrink-0 ml-6" external={true}>
      <Icon name="lucide:file-text" class="w-4 h-4 shrink-0" />
      View PDF
    </Link>
  </div>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>research interests</Highlight></h2>
    <p class="text-sm">{cv.interests.join(', ')}</p>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>education</Highlight></h2>
    {cv.education.map(edu => (
      <div>
        <div class="flex justify-between items-baseline">
          <span class="font-medium">{edu.institution}</span>
          <span class="text-sm text-gray-500">{edu.location}</span>
        </div>
        <div class="flex justify-between items-baseline">
          <span class="text-sm">{edu.degree}</span>
          <span class="text-sm text-gray-500">{edu.graduated}</span>
        </div>
        <p class="text-sm mt-1">GPA: {edu.gpa}</p>
        <p class="text-sm text-gray-500 mt-1">
          <span class="italic">Relevant Coursework:</span> {edu.coursework.join(', ')}
        </p>
      </div>
    ))}
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>research experience</Highlight></h2>
    <div class="space-y-6">
      {cv.research.map(r => (
        <div>
          {r.link
            ? <a href={r.link} target="_blank" rel="noopener" class="font-medium text-blue-500 hover:underline">{r.title}</a>
            : <p class="font-medium">{r.title}</p>
          }
          <div class="flex justify-between items-baseline">
            <span class="text-sm text-gray-500 italic">{r.organization}, {r.location}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{dash(r.dates)}</span>
          </div>
          <ul class="mt-1 list-disc list-inside text-sm space-y-0.5">
            {r.bullets.map(b => <li>{dash(b)}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>honors & awards</Highlight></h2>
    <div class="space-y-4">
      {cv.awards.map(a => (
        <div>
          <div class="flex justify-between items-baseline">
            <span class="font-medium">{a.title}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{dash(a.dates)}</span>
          </div>
          <div class="flex justify-between items-baseline">
            <span class="text-sm text-gray-500 italic">{a.organization}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{a.note}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4"><Highlight>teaching experience</Highlight></h2>
    <div class="space-y-4">
      {cv.teaching.map(t => (
        <div>
          <div class="flex justify-between items-baseline">
            <span class="font-medium">{t.title}</span>
            <span class="text-sm text-gray-500 ml-4 shrink-0">{dash(t.dates)}</span>
          </div>
          <span class="text-sm text-gray-500 italic">{t.organization}, {t.location}</span>
          <p class="text-sm">{dash(t.courses)}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-4"><Highlight>skills</Highlight></h2>
    <div class="space-y-1">
      {Object.entries(cv.skills).map(([cat, items]) => (
        <p class="text-sm">
          <span class="font-medium">{cat}:</span> {(items as string[]).join(', ')}
        </p>
      ))}
    </div>
  </section>
</Layout>
