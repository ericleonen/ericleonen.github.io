---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';
import Highlight from '../components/Highlight.astro';
import Emoji from '../components/Emoji.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg';

const homeRaw = await import('../content/home.md');
const { frontmatter } = homeRaw;
const Content = homeRaw.default;

// Parse [text](url) markdown links within a string into segments
function parseLinks(text: string): Array<{ text: string; url?: string }> {
  const parts: Array<{ text: string; url?: string }> = [];
  const re = /\[([^\]]+)\]\(([^)]+)\)/g;
  let last = 0, match;
  while ((match = re.exec(text)) !== null) {
    if (match.index > last) parts.push({ text: text.slice(last, match.index) });
    parts.push({ text: match[1], url: match[2] });
    last = match.index + match[0].length;
  }
  if (last < text.length) parts.push({ text: text.slice(last) });

  return parts;
}
---

<Layout title={frontmatter.name}>

  <!-- Profile -->
  <section class="flex flex-col sm:flex-row sm:items-center gap-5 mb-12">
    <Image
      src={profileImg}
      alt={frontmatter.name}
      width={128}
      height={128}
      class="w-32 h-32 sm:w-20 sm:h-20 shrink-0 rounded-full object-cover bg-gray-200 border-orange-200 border-4 hover:animate-wiggle"
    />
    <div>
      <h1 class="text-2xl font-bold mb-3"><Highlight>{frontmatter.name}</Highlight></h1>

      <!-- GitHub + LinkedIn -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm mb-1.5">
        <Link href={frontmatter.github} external>
          <span class="inline-flex items-center gap-1.5">
            <Icon name="simple-icons:github" class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
            GitHub
          </span>
        </Link>
        <Link href={frontmatter.linkedin} external>
          <span class="inline-flex items-center gap-1.5">
            <Icon name="simple-icons:linkedin" class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
            LinkedIn
          </span>
        </Link>
      </div>

      <!-- Emails -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500">
        {frontmatter.emails.map((email: string) => {
          const isUW = email.includes('uw.edu');
          return (
            <span class="inline-flex items-center gap-1.5">
              {isUW
                ? <Icon name="lucide:landmark" class="w-3.5 h-3.5 shrink-0" aria-label="UW" />
                : <Icon name="lucide:mail" class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
              }
              {email}
            </span>
          );
        })}
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-3"><Highlight>about me</Highlight></h2>
    <div class="text-gray-800 leading-relaxed prose prose-gray max-w-none">
      <Content />
      <p>
        Outside of academics, I'm a <Emoji>🏃🏽‍♂️‍➡️</Emoji> <Link href="https://www.strava.com/athletes/179900367" external>marathoner-in-training</Link>,
        an <Emoji>📖</Emoji> avid <Link href="https://www.goodreads.com/user/show/138760057-eric-leonen" external>reader</Link>,
        a <Emoji>⛳</Emoji> washed <Link href="https://wjga.bluegolf.com/bluegolf/wjga22/event/wjga228/contest/9/contestant/568/scorecard.htm" external>golfer</Link>,
        and a <Emoji>⚡</Emoji> Marvel Rivals <Link href="https://rivalsmeta.com/player/1371311011" external>Thor main</Link>.
      </p>
    </div>
  </section>

  <!-- Working On -->
  <section>
    <h2 class="text-lg font-semibold mb-3"><Highlight>works in progress</Highlight></h2>
    <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-2">
      {frontmatter.workingOn.map((item: { text: string; date?: string }) => (
        <Fragment>
          <span class="text-gray-400 select-none">{">"}</span>
          <span class="text-gray-800">
            {parseLinks(item.text).map(seg =>
              seg.url
                ? <Link href={seg.url}>{seg.text}</Link>
                : seg.text
            )}
            {item.date && (
              <span
                data-countdown={item.date}
                class="font-medium"
              ></span>
            )}
          </span>
        </Fragment>
      ))}
    </div>

    <script>
      // astro:page-load fires on first load and after every client-side navigation
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll<HTMLElement>('[data-countdown]').forEach(el => {
          const date = el.dataset.countdown;
          if (!date) return;
          const [ey, em, ed] = date.split('-').map(Number);
          const eventUTC = Date.UTC(ey, em - 1, ed);
          const todaySeattle = new Intl.DateTimeFormat('en-CA', {
            timeZone: 'America/Los_Angeles',
            year: 'numeric', month: '2-digit', day: '2-digit',
          }).format(new Date());
          const [ty, tm, td] = todaySeattle.split('-').map(Number);
          const todayUTC = Date.UTC(ty, tm - 1, td);
          const diff = eventUTC - todayUTC;
          if (diff < 0) return;
          const days = Math.round(diff / 86400000);
          el.textContent = days === 0 ? '(today!!!)' : days === 1 ? '(tomorrow!)' : `(${days} days left)`;
          el.className += days > 14 ? ' text-green-600' : days > 7 ? ' text-orange-600' : ' text-red-600';
        });
      });
    </script>
  </section>

</Layout>
