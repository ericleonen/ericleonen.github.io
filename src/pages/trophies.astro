---
import Layout from '../layouts/Layout.astro';
import Highlight from '../components/Highlight.astro';
import Link from '../components/Link.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const allTrophies = await getCollection('trophies');

const IMAGE_EXTS = ['.png', '.jpg', '.jpeg', '.webp', '.gif'];

function findTrophyImage(id: string): string | null {
  const dir = path.join(process.cwd(), 'public', 'trophies');
  for (const ext of IMAGE_EXTS) {
    const file = path.join(dir, id + ext);
    if (fs.existsSync(file)) return `/trophies/${id}${ext}`;
  }
  return null;
}

type Trophy = typeof allTrophies[number];
const byDate = (a: Trophy, b: Trophy) => b.data.date.valueOf() - a.data.date.valueOf();

const hydrated = await Promise.all(
  allTrophies.map(async item => ({
    ...item,
    image: findTrophyImage(item.id),
    Content: (await render(item)).Content,
  }))
);

const groups = new Map<string, typeof hydrated>();
for (const item of hydrated) {
  const key = item.data.type;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(item);
}

const sections = Array.from(groups.entries())
  .map(([type, items]) => ({ type, items: items.sort(byDate) }))
  .sort((a, b) => b.items[0].data.date.valueOf() - a.items[0].data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<Layout title="Trophies — Eric Leonen">
  <h1 class="text-2xl font-bold mb-8">Trophies</h1>

  {sections.length > 0
    ? sections.map(section => (
      <section class="mb-10 last:mb-0">
        <h2 class="text-lg font-semibold mb-4"><Highlight>{section.type}</Highlight></h2>
        <div class="flex flex-wrap gap-4">
          {section.items.map(item => (
            <div class="trophy-trigger relative" tabindex="0">
              {item.image
                ? (
                  <img
                    src={item.image}
                    alt={item.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-32 w-auto rounded border border-gray-200"
                  />
                )
                : (
                  <div class="h-32 w-32 rounded border border-gray-200 bg-gray-100" aria-label={item.data.title} />
                )
              }
              <template class="trophy-content">
                <div>
                  <h3 class="font-medium">{item.data.title}</h3>
                  <div class="flex flex-wrap items-baseline gap-x-3 text-sm mt-1">
                    <span class="text-xs text-gray-400 shrink-0">{formatDate(item.data.date)}</span>
                    {item.data.links?.map(link => (
                      <Link href={link.url} external>{link.label}</Link>
                    ))}
                  </div>
                  <div class="text-sm text-gray-700 mt-3 prose prose-sm prose-gray max-w-none">
                    <item.Content />
                  </div>
                </div>
              </template>
            </div>
          ))}
        </div>
      </section>
    ))
    : <p class="text-sm text-gray-400">Nothing here yet.</p>
  }
</Layout>

<script>
  import tippy from 'tippy.js';
  import 'tippy.js/dist/tippy.css';

  const canHover = window.matchMedia('(hover: hover)').matches;

  document.querySelectorAll<HTMLElement>('.trophy-trigger').forEach(trigger => {
    const tpl = trigger.querySelector<HTMLTemplateElement>('template.trophy-content');
    if (!tpl) return;
    const content = tpl.innerHTML;
    tippy(trigger, {
      content,
      allowHTML: true,
      interactive: true,
      placement: 'bottom',
      appendTo: () => document.body,
      maxWidth: 320,
      offset: [0, 8],
      delay: canHover ? [80, 100] : 0,
      animation: 'shift-away',
      theme: 'trophy',
      trigger: canHover ? 'mouseenter focus' : 'click',
      hideOnClick: canHover ? true : 'toggle',
      popperOptions: {
        modifiers: [
          { name: 'preventOverflow', options: { padding: 8 } },
          { name: 'flip', options: { padding: 8, fallbackPlacements: ['top', 'right', 'left'] } },
        ],
      },
    });
  });
</script>

<style is:global>
  .tippy-box[data-theme~='trophy'] {
    background: var(--color-paper, #f8f5ee);
    color: #111;
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.08);
  }
  .tippy-box[data-theme~='trophy'] > .tippy-content {
    padding: 1rem;
  }
  .tippy-box[data-theme~='trophy'] > .tippy-arrow {
    color: var(--color-paper, #f8f5ee);
  }
  .tippy-box[data-theme~='trophy'][data-placement^='top'] > .tippy-arrow::before {
    border-top-color: var(--color-paper, #f8f5ee);
  }
  .tippy-box[data-theme~='trophy'][data-placement^='bottom'] > .tippy-arrow::before {
    border-bottom-color: var(--color-paper, #f8f5ee);
  }
  .tippy-box[data-theme~='trophy'][data-placement^='left'] > .tippy-arrow::before {
    border-left-color: var(--color-paper, #f8f5ee);
  }
  .tippy-box[data-theme~='trophy'][data-placement^='right'] > .tippy-arrow::before {
    border-right-color: var(--color-paper, #f8f5ee);
  }
</style>
