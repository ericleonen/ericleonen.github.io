---
import Layout from '../layouts/Layout.astro';
import Highlight from '../components/Highlight.astro';
import fs from 'node:fs';
import path from 'node:path';

const IMAGE_EXTS = new Set(['.png', '.jpg', '.jpeg', '.webp', '.gif']);

const dir = path.join(process.cwd(), 'public', 'trophies');
const images = fs.existsSync(dir)
  ? fs.readdirSync(dir)
      .filter(f => IMAGE_EXTS.has(path.extname(f).toLowerCase()))
      .sort()
      .map(f => `/trophies/${f}`)
  : [];
---

<Layout title="Trophies — Eric Leonen">
  <h1 class="text-2xl font-bold mb-3"><Highlight>Trophies</Highlight></h1>
  <p class="text-gray-800 leading-relaxed mb-8">
    A collection of my greatest treasures. You'll have to guess what they are (though some are pretty obvious).
  </p>

  {images.length > 0
    ? (
      <div class="flex flex-wrap gap-4">
        {images.map(src => (
          <img
            src={src}
            alt=""
            loading="lazy"
            decoding="async"
            class="h-32 w-auto transition-transform duration-200 hover:-translate-y-1 hover:scale-105 hover:rotate-2"
          />
        ))}
      </div>
    )
    : <div class="text-6xl opacity-20 select-none">🏆</div>
  }
</Layout>
